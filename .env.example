# SpendGuard API — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Supabase — create project at supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# OpenAI — used only for semantic intent classification (Loop 5)
OPENAI_API_KEY=your-openai-api-key

# Admin key — used for POST /v1/keys to create API keys
ADMIN_API_KEY=your-admin-key-for-creating-api-keys

# Application
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# Rate limiting
RATE_LIMIT_DEMO_RPM=10       # Unauthenticated /v1/simulate — per IP
RATE_LIMIT_DEFAULT_RPM=100   # Authenticated requests — per API key

# MCP Server (used by mcp/server.py and mcp/client.py)
SPENDGUARD_API_URL=https://your-railway-url.up.railway.app
SPENDGUARD_API_KEY=sg_live_your_key_here
