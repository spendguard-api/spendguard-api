# SpendGuard API — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Supabase — create project at supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# OpenAI — used only for semantic intent classification (Loop 5)
OPENAI_API_KEY=your-openai-api-key

# Application
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# Rate limiting
RATE_LIMIT_DEMO_RPM=10       # Unauthenticated /v1/simulate — per IP
RATE_LIMIT_DEFAULT_RPM=100   # Authenticated requests — per API key
